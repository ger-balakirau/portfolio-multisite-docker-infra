TZ=Europe/Moscow

BASE_DIR=/opt/portfolio-multisite
RELEASE_ID=local

SITE_A_PROJECT_PATH=/opt/portfolio-multisite/site-a
SITE_A_STORAGE_PATH=/opt/portfolio-multisite/site-a/storage
SITE_B_PROJECT_PATH=/opt/portfolio-multisite/site-b
SITE_C_PROJECT_PATH=/opt/portfolio-multisite/site-c

PHP_VERSION=8.5
PHP_IMAGE_NAME=portfolio-multisite-php:8.5
PHP_PULL_POLICY=always
SITE_A_PHP_IMAGE=ghcr.io/example/portfolio-site-a-php:latest
SITE_B_PHP_IMAGE=ghcr.io/example/portfolio-site-b-php:latest
SITE_C_PHP_IMAGE=ghcr.io/example/portfolio-site-c-php:latest

NGINX_VERSION=1.30.1
NGINX_IMAGE_NAME=portfolio-multisite-nginx:1.30.1
LOCAL_NGINX_IMAGE_NAME=portfolio-multisite-nginx:local

SITE_A_MYSQL_PORT=127.0.0.1:33061
SITE_A_FPM_PORT=127.0.0.1:9001
SITE_B_FPM_PORT=127.0.0.1:9002
SITE_C_FPM_PORT=127.0.0.1:9003

SITE_A_LEGACY_FPM_PORT=127.0.0.1:9011
SITE_B_LEGACY_FPM_PORT=127.0.0.1:9012
SITE_C_LEGACY_FPM_PORT=127.0.0.1:9013

LOCAL_SITE_A_HTTP_PORT=8081
LOCAL_SITE_B_HTTP_PORT=8082
LOCAL_SITE_C_HTTP_PORT=8083

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# Used by scripts/issue-cert.sh.
CERTBOT_EMAIL=admin@example.com
